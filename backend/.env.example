# انسخي هذا الملف باسم .env وعدّلي القيم حسب الحاجة
# Copy this file as .env and adjust values as needed

PORT=4000

# مفتاح سري للتوثيق (JWT) — غيّريه إلى نص عشوائي طويل قبل النشر الحقيقي
JWT_SECRET=papillon-rose-super-secret-change-me-before-production

# رقم واتساب المتجر بصيغة دولية بدون + وبدون مسافات
# مثال: إذا كان رقمك 0550 12 34 56 اكتبيه هكذا: 213550123456
STORE_WHATSAPP_NUMBER=213550000000
